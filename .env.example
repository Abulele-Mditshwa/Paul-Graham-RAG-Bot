# 🚨 CRITICAL: AWS Configuration for Paul Graham RAG System
# 
# The default values in src/config.py belong to the original developer 
# and will NOT work for you. You must replace them with your own AWS resources.
#
# REQUIRED: Set these environment variables with YOUR AWS resource IDs:

# Your AWS Bedrock Knowledge Base ID (create your own with Paul Graham essays)
KNOWLEDGE_BASE_ID=your_knowledge_base_id_here

# Your OpenSearch Serverless collection name (create your own)
OPENSEARCH_COLLECTION_NAME=your_collection_name_here

# Your preferred AWS region (ensure Bedrock access)
AWS_REGION=us-east-1

# LLM Model ID (ensure access in your AWS account)
LLM_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# Optional: AWS Profile (if using named profiles)
AWS_PROFILE=default

# Instructions:
# 1. Copy this file to .env
# 2. Replace the placeholder values with your actual AWS resource IDs
# 3. Ensure you have AWS credentials configured (aws configure)
# 4. Run: streamlit run app.py

# Legacy fields (not used in current implementation)
OPENSEARCH_ENDPOINT=
EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0